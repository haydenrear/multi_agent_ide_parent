{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://multi-agent-ide/schemas/ai-policy-registration-request.schema.json",
  "title": "AiPolicyRegistrationRequest",
  "description": "Registration request for the dedicated AI filter endpoint. Uses PolicyRegistrationRequest shape with executor constrained to AI.",
  "type": "object",
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "sourcePath": { "type": "string", "minLength": 1 },
    "priority": { "type": "integer", "minimum": 0 },
    "isInheritable": { "type": "boolean" },
    "isPropagatedToParent": { "type": "boolean" },
    "layerBindings": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "filter-policy.schema.json#/$defs/PolicyLayerBinding" }
    },
    "executor": { "$ref": "filter-policy.schema.json#/$defs/AiExecutorConfig" },
    "activate": { "type": "boolean" }
  },
  "required": [
    "name",
    "description",
    "sourcePath",
    "priority",
    "isInheritable",
    "isPropagatedToParent",
    "layerBindings",
    "executor",
    "activate"
  ],
  "additionalProperties": false
}
