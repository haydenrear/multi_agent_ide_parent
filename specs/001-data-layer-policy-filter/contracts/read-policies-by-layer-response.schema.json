{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://multi-agent-ide/schemas/read-policies-by-layer-response.schema.json",
  "title": "ReadPoliciesByLayerResponse",
  "description": "Response for reading policies for a target layer.",
  "type": "object",
  "properties": {
    "layerId": { "type": "string", "minLength": 1 },
    "policies": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "policyId": { "type": "string", "minLength": 1 },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "sourcePath": { "type": "string" },
          "filterType": {
            "type": "string",
            "enum": ["JSON_PATH", "MARKDOWN_PATH", "REGEX_PATH", "AI_PATH"]
          },
          "status": { "type": "string", "enum": ["ACTIVE", "INACTIVE"] },
          "priority": { "type": "integer", "minimum": 0 }
        },
        "required": [
          "policyId",
          "name",
          "description",
          "sourcePath",
          "filterType",
          "status",
          "priority"
        ],
        "additionalProperties": false
      }
    },
    "totalCount": { "type": "integer", "minimum": 0 }
  },
  "required": ["layerId", "policies", "totalCount"],
  "additionalProperties": false
}
