{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://multi-agent-ide/schemas/policy-registration-request.schema.json",
  "title": "PolicyRegistrationRequest",
  "description": "Registration request sent to non-AI per-filter-type endpoints. The filterType is implicit from the endpoint path, so the request body contains only the executor config and common policy fields (no FilterDefinition, no inputType/outputType). AI endpoint uses ai-policy-registration-request.schema.json.",
  "type": "object",
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "sourcePath": { "type": "string", "minLength": 1 },
    "priority": { "type": "integer", "minimum": 0 },
    "isInheritable": { "type": "boolean" },
    "isPropagatedToParent": { "type": "boolean" },
    "layerBindings": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "filter-policy.schema.json#/$defs/PolicyLayerBinding" }
    },
    "executor": {
      "$ref": "filter-policy.schema.json#/$defs/ExecutorOneOf"
    },
    "activate": { "type": "boolean" }
  },
  "required": [
    "name",
    "description",
    "sourcePath",
    "priority",
    "isInheritable",
    "isPropagatedToParent",
    "layerBindings",
    "executor",
    "activate"
  ],
  "additionalProperties": false
}
